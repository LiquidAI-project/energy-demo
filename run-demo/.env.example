# Port for the frontend application.
FRONTEND_PORT=5173

# Whether to use the internal host for the orchestrator URL when sending deployments to supervisors.
# Should be true when using Docker containers for the orchestrator and the supervisors, and false otherwise.
USE_INTERNAL_HOST=true


# Comma-separated list of allowed hosts for the Vite development server.
VITE_ALLOWED_HOSTS=localhost

# Flag to indicate if this is a development version.
VITE_DEV_VERSION=true
